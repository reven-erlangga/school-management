{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist", "**/*.test.ts", "**/*.test.svelte.ts"],
  "compilerOptions": {
    "strictNullChecks": true,
    "types": ["vitest/globals", "node"],
    "baseUrl": ".",
    "paths": {
      "@modules/*": ["src/modules/*"],
      "@components/*": ["src/components/*"],
      "@pages/*": ["src/pages/*"],
      "@styles/*": ["src/styles/*"],
      "@layouts/*": ["src/layouts/*"],
      "@store/*": ["src/store/*"],
      "@utils/*": ["src/utils/*"]
    }
  }
}
